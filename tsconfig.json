{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "**/*.js"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test",
    ".tickets",
    "config/config.js",
    "utils.js",
    "services/matchGenerators.js",
    "services/tournamentAdvancers.js",
    "controllers/memberController.js",
    "controllers/tournament/bracketController.js",
    "controllers/tournament/index.js",
    "controllers/tournament/matchController.js",
    "controllers/tournament/tournamentController.js"
  ]
}
